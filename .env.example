# ====================================
# TVDS — Environment Variables
# ====================================
# Copy this file to backend/.env and fill in your values.
# ====================================

# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/tvds

# JWT (generate a strong random secret: `openssl rand -hex 32`)
JWT_SECRET=your_jwt_secret_key_here

# Application URLs
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173
AI_SERVICE_URL=http://localhost:8000

# eSewa Payment Gateway
ESEWA_SCD=EPAYTEST
ESEWA_SECRET=your_esewa_secret_here

# Khalti Payment Gateway
KH_SECRET_KEY=your_khalti_secret_key_here

# AI Service
AI_API_KEY=tvds-ai-key-dev
